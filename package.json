{
  "name": "pestto",
  "version": "0.1.1",
  "description": "Extensão minimalista para conversão automática de Markdown ao colar texto no WhatsApp Web.",
  "main": "content.js",
  "config": {
    "zipName": "pestto-latest.zip"
  },
  "scripts": {
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "rm -f $npm_package_config_zipName && zip -q $npm_package_config_zipName manifest.json content.js converter.js version.js icon-128.png",
    "version": "node sync-version.js && git add manifest.json",
    "undo-version": "git tag -d $(git tag --points-at HEAD) && git reset --hard HEAD~1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axmbo/pestto.git"
  },
  "keywords": [
    "chrome-extension",
    "whatsapp",
    "markdown",
    "clipboard"
  ],
  "author": "axmbo",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/axmbo/pestto/issues"
  },
  "homepage": "https://github.com/axmbo/pestto#readme",
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  }
}
