{
  "manifest_version": 3,
  "name": "Pestto",
  "version": "0.4.0",
  "description": "Converte Markdown automaticamente ao colar texto no WhatsApp Web.",
  "icons": {
    "16": "src/icons/icon-16.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/version.js", "src/converter.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
